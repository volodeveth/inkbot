{
  "name": "inkbot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npx prisma generate && npx remix vite:build",
    "dev": "shopify app dev",
    "dev:remix": "remix vite:dev",
    "start": "npx remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "npx prisma generate && npx prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "postinstall": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate deploy",
    "db:studio": "npx prisma studio"
  },
  "type": "module",
  "engines": {
    "node": ">=18.20.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.0",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@remix-run/serve": "^2.15.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-app-remix": "^3.4.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.1.0",
    "isbot": "^5.1.0",
    "openai": "^6.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.15.0",
    "@shopify/api-codegen-preset": "^1.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "eslint": "^8.57.0",
    "prisma": "^5.22.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^4.3.0"
  }
}
